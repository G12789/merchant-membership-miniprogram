/* pages/members/members.wxss */
/* 高端 SaaS 工具质感 */

.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
  background-color: #fafafa;
  min-height: 100vh;
}

/* 搜索栏 */
.search-bar {
  margin-bottom: 16rpx;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.clear-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  margin-bottom: 20rpx;
  padding: 8rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #8c8c8c;
  border-radius: 12rpx;
  transition: all 0.2s ease;
}

.filter-tab.active {
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  color: #fff;
  font-weight: 500;
}

/* 统计信息 */
.stats-bar {
  display: flex;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1890ff;
}

.stats-label {
  display: block;
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 8rpx;
}

/* 会员卡片 */
.member-list {
  margin: 0;
}

.member-card {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s ease;
}

.member-card:active {
  transform: scale(0.99);
}

.member-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  background: linear-gradient(135deg, #e6fffb 0%, #f0fff4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-emoji {
  font-size: 40rpx;
}

.member-info {
  flex: 1;
  min-width: 0;
}

.member-name-row {
  display: flex;
  align-items: center;
}

.member-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-phone {
  display: block;
  font-size: 26rpx;
  color: #8c8c8c;
  margin-top: 6rpx;
}

.member-time {
  display: block;
  font-size: 22rpx;
  color: #bfbfbf;
  margin-top: 4rpx;
}

.member-balance {
  text-align: right;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.balance-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1890ff;
}

.balance-label {
  display: block;
  font-size: 22rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 28rpx;
  color: #8c8c8c;
  margin-bottom: 32rpx;
}

.empty-btn {
  width: 280rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
}

.unlock-tip-inline {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 20rpx;
}

.unlock-tip-inline text:first-child {
  font-size: 26rpx;
  color: #8c8c8c;
}

.unlock-link {
  font-size: 28rpx;
  color: #1890ff;
  margin-top: 12rpx;
  font-weight: 500;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #8c8c8c;
}

/* 底部添加按钮 */
.add-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  color: #fff;
  border-radius: 46rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.25);
  transition: transform 0.15s ease;
}

.add-btn:active {
  transform: scale(0.98);
}

.add-btn.disabled {
  background: #f5f5f5;
  color: #bfbfbf;
  box-shadow: none;
}

.add-icon {
  font-size: 36rpx;
  margin-right: 8rpx;
}

/* 底部智能提示条 */
.smart-tip-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 140rpx);
  background: linear-gradient(135deg, #f0f5ff 0%, #e6f7ff 100%);
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 16rpx rgba(24, 144, 255, 0.12);
  z-index: 100;
}

.smart-tip-text {
  flex: 1;
  font-size: 26rpx;
  color: #595959;
}

.smart-tip-action {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 500;
  padding-left: 16rpx;
}

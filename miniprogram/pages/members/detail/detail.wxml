<!--pages/members/detail/detail.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view class="loading-wrap" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <block wx:if="{{!loading && memberInfo}}">
    <!-- 会员头像和基本信息 -->
    <view class="profile-card">
      <view class="profile-avatar">
        <text class="avatar-emoji">👤</text>
      </view>
      <view class="profile-info">
        <text class="profile-name">{{memberInfo.name}}</text>
        <view class="profile-phone" bindtap="callPhone">
          <text>{{memberInfo.phone}}</text>
          <text class="phone-call-icon">📞</text>
        </view>
      </view>
      <view class="profile-balance">
        <text class="balance-value">¥{{memberInfo.balanceText}}</text>
        <text class="balance-label">余额</text>
      </view>
    </view>

    <!-- 快捷操作按钮 -->
    <view class="action-btns">
      <view class="action-btn" bindtap="recharge">
        <view class="action-icon recharge-icon">+</view>
        <text>充值</text>
      </view>
      <view class="action-btn" bindtap="consume">
        <view class="action-icon consume-icon">-</view>
        <text>消费</text>
      </view>
      <view class="action-btn" bindtap="sendSms">
        <image src="/images/icons/message.png" mode="aspectFit"></image>
        <text>发短信</text>
      </view>
      <view class="action-btn" bindtap="callPhone">
        <image src="/images/icons/phone.png" mode="aspectFit"></image>
        <text>打电话</text>
      </view>
    </view>

    <!-- 详细信息卡片 -->
    <view class="info-card">
      <view class="card-title">会员信息</view>
      
      <view class="info-item">
        <text class="info-label">姓名</text>
        <text class="info-value">{{memberInfo.name}}</text>
      </view>
      
      <view class="info-item">
        <text class="info-label">手机号</text>
        <text class="info-value">{{memberInfo.phone}}</text>
      </view>
      
      <view class="info-item">
        <text class="info-label">性别</text>
        <text class="info-value">{{memberInfo.genderText}}</text>
      </view>
      
      <view class="info-item">
        <text class="info-label">生日</text>
        <text class="info-value">{{memberInfo.birthdayText}}</text>
      </view>
      
      <view class="info-item">
        <text class="info-label">加入时间</text>
        <text class="info-value">{{memberInfo.createTimeText}}</text>
      </view>
      
      <view class="info-item" wx:if="{{memberInfo.remark}}">
        <text class="info-label">备注</text>
        <text class="info-value remark">{{memberInfo.remark}}</text>
      </view>
    </view>

    <!-- 消费记录 -->
    <view class="info-card">
      <view class="card-title">消费记录</view>
      
      <view class="transaction-list" wx:if="{{transactionList.length > 0}}">
        <view class="transaction-item" wx:for="{{transactionList}}" wx:key="_id">
          <view class="transaction-left">
            <text class="transaction-type">{{item.typeText}}</text>
            <text class="transaction-time">{{item.createTimeText}}</text>
          </view>
          <view class="transaction-right">
            <text class="transaction-amount {{item.amount > 0 ? 'positive' : 'negative'}}">{{item.amountText}}</text>
            <text class="transaction-balance">余额: ¥{{item.balanceText}}</text>
          </view>
        </view>
      </view>
      
      <view class="empty-transaction" wx:else>
        <text>暂无消费记录</text>
      </view>
    </view>

    <!-- 底部操作按钮 -->
    <view class="bottom-btns">
      <button class="btn btn-outline" bindtap="deleteMember">删除会员</button>
    </view>
  </block>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && !memberInfo}}">
    <image class="empty-icon" src="/images/icons/empty.png" mode="aspectFit"></image>
    <text class="empty-text">会员信息不存在</text>
    <button class="btn btn-primary" bindtap="navigateBack">返回列表</button>
  </view>
</view>

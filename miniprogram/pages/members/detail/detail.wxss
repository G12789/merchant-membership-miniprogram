/* pages/members/detail/detail.wxss */
.container {
  padding: 20rpx;
  padding-bottom: 180rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 加载中 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e8e8e8;
  border-top-color: #1890ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #999;
}

/* 头像信息卡片 */
.profile-card {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: linear-gradient(135deg, #1890ff 0%, #36cfc9 100%);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.profile-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-emoji {
  font-size: 56rpx;
}

.profile-info {
  flex: 1;
  margin-left: 24rpx;
}

.profile-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.profile-phone {
  display: flex;
  align-items: center;
}

.profile-phone text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.phone-icon {
  width: 32rpx;
  height: 32rpx;
  margin-left: 12rpx;
}

.phone-call-icon {
  margin-left: 12rpx;
  font-size: 28rpx;
}

.profile-balance {
  text-align: right;
}

.profile-balance .balance-value {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.profile-balance .balance-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

/* 快捷操作按钮 */
.action-btns {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
}

.action-btn image {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 12rpx;
}

.action-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.recharge-icon {
  background-color: #e6f7ff;
  color: #1890ff;
}

.consume-icon {
  background-color: #fff2e8;
  color: #fa8c16;
}

.action-btn text {
  font-size: 26rpx;
  color: #666;
}

.action-btn:active {
  opacity: 0.7;
}

/* 信息卡片 */
.info-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f9f9f9;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  flex: 1;
  margin-left: 20rpx;
  word-break: break-all;
}

.info-value.remark {
  color: #666;
}

/* 消费记录 */
.transaction-list {
  max-height: 500rpx;
  overflow-y: auto;
}

.transaction-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f9f9f9;
}

.transaction-item:last-child {
  border-bottom: none;
}

.transaction-left {
  display: flex;
  flex-direction: column;
}

.transaction-type {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.transaction-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.transaction-right {
  text-align: right;
}

.transaction-amount {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
}

.transaction-amount.positive {
  color: #52c41a;
}

.transaction-amount.negative {
  color: #ff4d4f;
}

.transaction-balance {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.empty-transaction {
  padding: 40rpx 0;
  text-align: center;
}

.empty-transaction text {
  font-size: 28rpx;
  color: #999;
}

/* 底部按钮 */
.bottom-btns {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn {
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
}

.btn-primary {
  background-color: #1890ff;
  color: #fff;
}

.btn-outline {
  background-color: #fff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
}

.btn-outline:active {
  background-color: #fff5f5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 40rpx;
}

.empty-state .btn {
  width: 300rpx;
}

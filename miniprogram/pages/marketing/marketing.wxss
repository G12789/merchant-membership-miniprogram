/* pages/marketing/marketing.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.marketing-list {
  margin-top: 10rpx;
}

.marketing-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.marketing-item:last-child {
  border-bottom: none;
}

.item-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #e6f7ff;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.item-icon image {
  width: 44rpx;
  height: 44rpx;
}

.item-info {
  flex: 1;
}

.item-title {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.item-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.item-arrow {
  font-size: 28rpx;
  color: #999;
}

.expired-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.lock-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.expired-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

<!--pages/data/data.wxml-->
<view class="container">
  <view class="card" wx:if="{{!isExpired}}">
    <view class="card-title">数据概览</view>
    <view class="stats-grid">
      <view class="stats-item">
        <text class="stats-value">{{stats.totalMembers}}</text>
        <text class="stats-label">会员总数</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{stats.monthNewMembers}}</text>
        <text class="stats-label">本月新增</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{stats.totalIncome}}</text>
        <text class="stats-label">总收入(元)</text>
      </view>
      <view class="stats-item">
        <text class="stats-value">{{stats.avgConsume}}</text>
        <text class="stats-label">客单价(元)</text>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{!isExpired}}">
    <view class="card-title">会员增长趋势</view>
    <view class="chart-placeholder">
      <text>图表区域（需接入echart组件）</text>
    </view>
  </view>

  <view class="card" wx:if="{{!isExpired}}">
    <view class="card-title">消费分析</view>
    <view class="chart-placeholder">
      <text>图表区域（需接入echart组件）</text>
    </view>
  </view>

  <!-- 过期遮罩 -->
  <view class="expired-mask" wx:if="{{isExpired}}">
    <view class="expired-content">
      <image class="lock-icon" src="/images/icons/lock.png" mode="aspectFit"></image>
      <text class="expired-title">数据分析功能已锁定</text>
      <text class="expired-desc">升级付费会员，解锁详细数据分析功能</text>
      <button class="btn btn-accent" bindtap="goToPayment">立即升级</button>
    </view>
  </view>
</view>

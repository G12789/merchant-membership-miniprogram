/* pages/data/data.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
}

.stats-item {
  width: 50%;
  text-align: center;
  padding: 20rpx 0;
}

.stats-value {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #1890ff;
}

.stats-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.chart-placeholder {
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f9f9f9;
  border-radius: 12rpx;
  color: #999;
  font-size: 26rpx;
}

.expired-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.expired-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.lock-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.expired-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.expired-desc {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 40rpx;
}

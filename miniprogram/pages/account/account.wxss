/* pages/account/account.wxss */
/* 账户与套餐中心 - 按需求文档重构 */

.container {
  padding: 24rpx;
  padding-bottom: 200rpx;
  background-color: #f7f8fa;
  min-height: 100vh;
}

/* 顶部用户信息 */
.user-header {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  margin-right: 24rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.user-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-emoji {
  font-size: 48rpx;
}

.avatar-emoji-small {
  font-size: 32rpx;
}

.info-avatar-wrap {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #e6fffb 0%, #f0fff4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
}

.user-phone {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 卡片通用样式 */
.card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 状态卡片 */
.status-card {
  padding: 24rpx 32rpx;
}

.status-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-left {
  display: flex;
  align-items: center;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-dot.trial {
  background-color: #07c160;
}

.status-dot.paid {
  background-color: #07c160;
}

.status-dot.expired {
  background-color: #ee0a24;
}

.status-dot.warning {
  background-color: #ff976a;
}

.status-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.status-expire {
  font-size: 26rpx;
  color: #999;
}

.trial-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.trial-text {
  font-size: 26rpx;
  color: #07c160;
}

/* 套餐升级区域 */
.plans-section {
  padding: 28rpx 32rpx;
}

.plan-list {
  margin-bottom: 24rpx;
}

.plan-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
}

.plan-item:last-child {
  margin-bottom: 0;
}

.plan-item.selected {
  border-color: #07c160;
  background-color: #f6ffed;
}

.plan-item:active {
  transform: scale(0.99);
}

/* 圆形选择按钮 */
.plan-radio {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 3rpx solid #c8c9cc;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.plan-item.selected .plan-radio {
  border-color: #07c160;
  background-color: #07c160;
}

.radio-inner {
  width: 16rpx;
  height: 16rpx;
  background-color: #fff;
  border-radius: 50%;
}

.plan-info {
  flex: 1;
}

.plan-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
}

/* 套餐价格 - 青绿色 */
.plan-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #1ac7b8;
}

/* 支付按钮 */
.pay-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
  margin-top: 24rpx;
}

.pay-btn[disabled] {
  background-color: #c8c9cc;
  color: #fff;
}

.pay-btn:active:not([disabled]) {
  background-color: #06ad56;
}

/* 账户信息区域 */
.info-section {
  padding: 28rpx 32rpx;
}

.info-list {
  margin-bottom: 24rpx;
}

.info-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.info-right {
  display: flex;
  align-items: center;
  flex: 1;
  justify-content: flex-end;
}

.info-value {
  font-size: 28rpx;
  color: #666;
  margin-right: 12rpx;
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.info-value.placeholder {
  color: #999;
}

.info-arrow {
  font-size: 28rpx;
  color: #c8c9cc;
}

.info-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

/* 操作按钮 */
.info-btn {
  padding: 10rpx 20rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
}

.upgrade-btn {
  background-color: #07c160;
  color: #fff;
}

.sms-btn {
  background-color: #07c160;
  color: #fff;
}

/* 店铺公告 */
.notice-section {
  padding-top: 16rpx;
}

.notice-section .info-label {
  display: block;
  margin-bottom: 16rpx;
}

.notice-input {
  width: 100%;
  height: 160rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  background-color: #f7f8fa;
  border-radius: 12rpx;
  box-sizing: border-box;
}

/* 底部功能按钮 */
.bottom-btns {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.bottom-btns .btn-primary {
  flex: 1;
  min-width: calc(50% - 8rpx);
  height: 80rpx;
  line-height: 80rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
  padding: 0;
  margin: 0;
}

.bottom-btns .btn-primary:active {
  background-color: #06ad56;
}

.bottom-btns .btn-outline {
  flex: 1;
  min-width: 100%;
  height: 80rpx;
  line-height: 76rpx;
  background-color: #fff;
  color: #333;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e8e8e8;
  padding: 0;
  margin: 0;
}

.bottom-btns .btn-outline:active {
  background-color: #f5f5f5;
}

/* 退出登录 */
.logout-section {
  text-align: center;
  padding: 40rpx 0;
}

.logout-btn {
  font-size: 28rpx;
  color: #999;
}

.logout-btn:active {
  color: #666;
}

/* 弹窗遮罩 */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

/* 弹窗容器 */
.popup-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 80vh;
  overflow: hidden;
}

.popup-container.show {
  transform: translateY(0);
}

/* 弹窗头部 */
.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.popup-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
}

.popup-close:active {
  color: #666;
}

/* 弹窗内容 */
.popup-content {
  padding: 24rpx 32rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.popup-content .plan-list {
  margin-bottom: 0;
}

/* 价格隐藏状态 */
.plan-price-hidden {
  font-size: 26rpx;
  color: #999;
}

/* 弹窗底部 */
.popup-footer {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid #f5f5f5;
}

.popup-pay-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background-color: #07c160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: none;
}

.popup-pay-btn[disabled] {
  background-color: #c8c9cc;
  color: #fff;
}

.popup-pay-btn:active:not([disabled]) {
  background-color: #06ad56;
}

/* pages/index/index.wxss */
/* 高端 SaaS 工具质感 */

.container {
  padding: 24rpx;
  padding-bottom: 140rpx;
}

/* 智能提示栏 */
.notice-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.notice-bar-trial {
  background: linear-gradient(135deg, #fafafa 0%, #f5f5f5 100%);
}

.notice-bar-trial .notice-content {
  color: #8c8c8c;
}

.notice-bar-warning {
  background: linear-gradient(135deg, #fff7e6 0%, #fffbe6 100%);
}

.notice-bar-warning .notice-content {
  color: #fa8c16;
}

.notice-bar-expired {
  background: linear-gradient(135deg, #fff1f0 0%, #ffccc7 100%);
}

.notice-bar-expired .notice-content {
  color: #cf1322;
}

.notice-bar-paid {
  background: linear-gradient(135deg, #f6ffed 0%, #e6fffb 100%);
}

.notice-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  opacity: 0.8;
}

.notice-icon image {
  width: 100%;
  height: 100%;
}

.notice-content {
  flex: 1;
  font-size: 26rpx;
  color: #595959;
  line-height: 1.5;
}

.notice-action {
  margin-left: 16rpx;
}

.notice-link {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 500;
}

/* 登录卡片 */
.login-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx;
}

.login-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #f0f5ff 0%, #e6f7ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.12);
}

.login-icon {
  width: 80rpx;
  height: 80rpx;
  opacity: 0.85;
}

.login-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 16rpx;
  letter-spacing: 1rpx;
}

.login-desc {
  font-size: 28rpx;
  color: #8c8c8c;
  margin-bottom: 48rpx;
}

.login-card .btn {
  width: 80%;
}

/* 统计卡片 - 渐变蓝色 */
.stats-card {
  background: linear-gradient(135deg, #1890ff 0%, #40a9ff 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.25);
}

.stats-card .card-title {
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-item .stat-number {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: -1rpx;
}

.stats-item .stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 8rpx;
}

/* 快捷操作网格 - 2x2布局 */
.grid-2x2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 8rpx 0;
}

.grid-item-2x2 {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 16rpx;
  background: #fafafa;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.2s ease;
}

.grid-item-2x2:active {
  transform: scale(0.98);
  background: #f0f0f0;
}

/* 图标盒子 - 青绿色主题 */
.icon-box {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #e6fffb 0%, #f0fff4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(26, 199, 184, 0.15);
}

.icon-text {
  font-size: 40rpx;
}

.icon-box-disabled {
  background: linear-gradient(135deg, #f5f5f5 0%, #fafafa 100%);
  opacity: 0.6;
  box-shadow: none;
}

.grid-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.unlock-hint {
  font-size: 20rpx;
  color: #1ac7b8;
  margin-top: 8rpx;
}

/* 次要功能横排 */
.sub-actions {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  padding-top: 24rpx;
  margin-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.sub-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
}

.sub-action-item:active {
  opacity: 0.7;
}

.sub-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.sub-label {
  font-size: 24rpx;
  color: #666;
}

/* 营销效果卡片 */
.data-card {
  position: relative;
  overflow: hidden;
}

.blur-mask-container {
  position: relative;
}

.data-overview {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 0;
}

.data-item {
  text-align: center;
}

.data-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1890ff;
}

.data-label {
  display: block;
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 8rpx;
}

/* 模糊遮罩 - 比斑璇效果 */
.blur-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(255,255,255,0.75) 0%, rgba(250,250,250,0.95) 100%);
  backdrop-filter: blur(6px);
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
}

.blur-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.lock-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 16rpx;
  opacity: 0.6;
}

.blur-text {
  font-size: 28rpx;
  color: #595959;
  margin-bottom: 12rpx;
}

.blur-link {
  font-size: 28rpx;
  color: #1890ff;
  font-weight: 500;
}

/* 会员列表 */
.card-header {
  margin-bottom: 20rpx;
}

.card-header .card-title {
  margin-bottom: 0;
}

.card-more {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: 500;
}

.member-list {
  margin: 0 -8rpx;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 8rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.15s ease;
}

.member-item:active {
  background-color: #fafafa;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  background: linear-gradient(135deg, #e6fffb 0%, #f0fff4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.member-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-emoji {
  font-size: 36rpx;
}

.member-info {
  flex: 1;
}

.member-name {
  display: block;
  font-size: 30rpx;
  color: #262626;
  font-weight: 500;
}

.member-phone {
  display: block;
  font-size: 24rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}

.member-balance {
  text-align: right;
}

.balance-value {
  display: block;
  font-size: 30rpx;
  color: #1890ff;
  font-weight: 600;
}

.balance-label {
  display: block;
  font-size: 22rpx;
  color: #8c8c8c;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 48rpx 0;
  color: #8c8c8c;
  font-size: 28rpx;
}

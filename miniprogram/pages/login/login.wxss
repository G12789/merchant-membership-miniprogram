/* pages/login/login.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1890ff 0%, #40a9ff 50%, #f5f5f5 50%);
  padding: 0 40rpx;
  padding-top: 100rpx;
  box-sizing: border-box;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 60rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
  background-color: #fff;
  border-radius: 32rpx;
  padding: 20rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.login-form {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.form-item {
  margin-bottom: 30rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  background-color: #f9f9f9;
  border-radius: 16rpx;
  padding: 0 24rpx;
  height: 100rpx;
}

.input-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
  opacity: 0.6;
}

.input {
  flex: 1;
  font-size: 30rpx;
}

.code-wrap {
  padding-right: 0;
}

.code-btn {
  width: 200rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  background-color: #1890ff;
  color: #fff;
  border-radius: 32rpx;
  margin: 0;
  padding: 0;
}

.code-btn.disabled {
  background-color: #d9d9d9;
  color: #999;
}

.login-btn {
  margin-top: 20rpx;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 34rpx;
  border-radius: 50rpx;
}

.agreement {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 30rpx;
  font-size: 24rpx;
  color: #999;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 50%;
  margin-right: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
}

.checkbox.checked {
  background-color: #1890ff;
  border-color: #1890ff;
}

.link {
  color: #1890ff;
}

.login-footer {
  margin-top: 60rpx;
}

.divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background-color: #e8e8e8;
}

.divider text {
  padding: 0 30rpx;
  font-size: 26rpx;
  color: #999;
}

.wechat-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
}

.wechat-btn image {
  width: 44rpx;
  height: 44rpx;
  margin-right: 16rpx;
}

.trial-tips {
  display: flex;
  justify-content: center;
  margin-top: 60rpx;
  padding-bottom: 60rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  margin: 0 20rpx;
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background-color: #52c41a;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 8rpx;
}

.tip-item text {
  font-size: 24rpx;
  color: #666;
}
